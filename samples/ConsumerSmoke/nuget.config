<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 4.5 Gate 2 (M4 DoD #7): the consumer restores the BlazorNative.*
     packages ONLY from the local pack output; nuget.org serves the transitive
     deps (ZeroAlloc.*, Microsoft.*). <clear /> drops every inherited source so
     nothing can leak in from user/machine configs. -->
<configuration>
  <packageSources>
    <clear />
    <add key="blazornative-local" value="../../artifacts/packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
