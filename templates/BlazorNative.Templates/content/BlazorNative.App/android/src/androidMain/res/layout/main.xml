<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Phase 6.1: the host root is a BnYogaFrameLayout, NOT a stock FrameLayout.
         A stock one is not inert: every addView/setText in a batch calls
         requestLayout(), and the ensuing traversal re-measures this container and
         re-places every TOP-LEVEL node at (0, 0, hostW, hostH) — behind Yoga's
         back, in the real Activity only (never in a detached-root test), and the
         resize listener's bounds guard sees no change so nothing repairs it. Yoga
         owns ALL placement, including the top level. See BnYogaFrameLayout's KDoc. -->
    <io.blazornative.shell.BnYogaFrameLayout
        android:id="@+id/widget_root"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF" />

    <!-- THE [BOOT] STRIP IS A FIXED HEIGHT, NOT A WEIGHTED FRACTION. It used to be
         `0dp` + `layout_weight="2"` against widget_root's `3` — a flat 40% of the
         screen in every orientation, in a SCAFFOLDED APP. A fraction is the wrong
         unit for a debug strip: it needs a couple of lines of text (an absolute
         amount of space) while your app needs everything else, so weighting it
         kept the full 40% precisely when there was none to spare. Rotating to
         landscape is where it shows: the app's area collapses to ~244dp on a
         407 × 904dp screen, content overflows widget_root, and because every
         BnYogaFrameLayout sets `clipChildren = false` the overflow is painted
         over by this opaque panel rather than clipped.

         96dp holds three lines of 14sp monospace inside the 16dp padding, and it
         scrolls, so no narration is lost. Delete this whole ScrollView if you do
         not want it — but then also drop MainActivity's `R.id.markers` lookup,
         which is what writes to it. -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="#000000"
        android:padding="16dp">

        <TextView
            android:id="@+id/markers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#00FF00"
            android:textSize="14sp"
            android:text="Booting native runtime..." />
    </ScrollView>
</LinearLayout>
