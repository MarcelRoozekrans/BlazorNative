<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The shell bridge's fetch handler (AndroidShellBridge →
         HttpURLConnection) does real network I/O, and Android requires INTERNET
         for ANY socket. Remove this only if your app truly never fetches. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Local notifications: POST_NOTIFICATIONS is the Android 13+ runtime
         permission the shell requests before show/schedule (inert below API 33,
         where notifications are implicitly permitted). The scheduled path uses an
         INEXACT AlarmManager alarm, so no SCHEDULE_EXACT_ALARM is needed. Remove
         this only if your app never posts notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Biometrics: USE_BIOMETRIC is a NORMAL permission (granted at install, no
         runtime prompt) that BiometricPrompt / BiometricManager use. Secure storage's
         raw AndroidKeyStore needs no manifest permission. Remove this only if your app
         never authenticates biometrically. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Camera photo capture via the ACTION_IMAGE_CAPTURE Intent path (NO runtime
         CAMERA permission — the system camera app owns the sensor and its permission;
         the shell only supplies the output URI). On API 30+ package visibility,
         resolving the camera app for the availability `check` needs this <queries>
         declaration. Remove this only if your app never captures photos. -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
    </queries>

    <application
        android:label="MyBlazorNativeApp"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <!-- FULLY QUALIFIED, deliberately. The relative form (".MainActivity")
             resolves against AGP's `namespace`, which is YOUR app id — but the
             shell's Kotlin lives in io.blazornative.shell (it is library code,
             copied byte-identically from the BlazorNative reference shell). The
             two identities are separate on purpose; naming the activity in full
             is what lets them differ. -->
        <activity
            android:name="io.blazornative.shell.MainActivity"
            android:launchMode="singleTop"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Launch-time deep links: blazornative://<route> opens the page
                 MainActivity's DEEP_LINK_COMPONENTS maps that route to. A custom
                 scheme needs no domain verification; https App Links are more
                 work and are yours to add. The scheme must match MainActivity's
                 DEEP_LINK_SCHEME constant. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="blazornative" />
            </intent-filter>
        </activity>

        <!-- The scheduled-notification publisher. MANIFEST-declared (not a runtime
             receiver) so a scheduled alarm still fires after the process is killed.
             The name is the nested binary form Outer$Inner
             (AndroidShellBridge.NotificationPublisher, library code in
             io.blazornative.shell). Not exported — only the app's own alarm targets it. -->
        <receiver
            android:name="io.blazornative.shell.AndroidShellBridge$NotificationPublisher"
            android:exported="false" />

        <!-- The FileProvider that supplies ACTION_IMAGE_CAPTURE's output URI. The system
             camera app writes the full-res JPEG to a content:// URI the shell grants it
             write access to (FLAG_GRANT_WRITE_URI_PERMISSION). The authority is
             ${applicationId}.fileprovider (AGP substitutes YOUR app id — it matches
             AndroidShellBridge.fileProviderAuthority, which reads packageName); the
             captures live in the app-cache subdir declared in res/xml/file_paths.xml.
             Not exported; grantUriPermissions so the per-launch write grant works. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
