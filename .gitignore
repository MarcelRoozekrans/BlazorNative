# Gradle build cache
.gradle/
.kotlin/
build/
# ...but the repo-root build/ holds vendored msbuild targets (Phase 3.0c), not Gradle output
!/build/
# ...and so does the 8.3 template's copy of it. Without this negation the Gradle
# rule above silently swallows BionicNativeAot.targets on its way into the pack,
# and a generated app gets NO bionic publish — no .so, no APK — for a reason
# nothing in the tree names. TemplateDriftTests pins the file's CONTENT; this
# line is what keeps the file in the checkout for it to see.
!/templates/BlazorNative.Templates/content/BlazorNative.App/build/

# Phase 2.2 - Android Gradle copy task outputs (regenerated by gradle preBuild)
src/BlazorNative.Jni/src/androidMain/assets/
src/BlazorNative.Jni/src/androidMain/jniLibs/

# Phase 11.0 - the deep-link route map, generated at build time by
# BlazorNative.RouteGen (GenerateBlazorNativeRoutes). A build artifact: the drift
# test regenerates + compares, so there is no checked-in copy to drift.
src/BlazorNative.Jni/src/androidMain/res/raw/blazornative_routes.json

# Phase 3.0c - NDK shims BionicNativeAot.targets writes next to the publishing csproj (deleted only when linking succeeds)
android_clang.cmd
android_llvm-objcopy.cmd

# Phase 5.2 - iOS Swift shell (src/BlazorNative.Apple)
#   - BnHost.xcodeproj is generated from project.yml by XcodeGen at CI time
#   - vendor/*.a is the NativeAOT static archive copied from the publish output
#   - DerivedData is Xcode's build cache
src/BlazorNative.Apple/BnHost.xcodeproj/
src/BlazorNative.Apple/vendor/*.a
src/BlazorNative.Apple/vendor/*.o
src/BlazorNative.Apple/DerivedData/
*.xcresult
