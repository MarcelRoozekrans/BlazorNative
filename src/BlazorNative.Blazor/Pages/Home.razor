@page "/"
@inject IMobileBridge Bridge
@implements IDisposable
@using BlazorNative.Core
@using ZeroAlloc.AsyncEvents

<PageTitle>BlazorNative</PageTitle>

<div class="shell-root">
    <header>
        <span class="platform-badge @Info?.Platform.ToString().ToLower()">
            @(Info?.Platform.ToString() ?? "…")
        </span>
        <h1>BlazorNative</h1>
        <p class="subtitle">v@(Info?.AppVersion ?? "…") · @(Info?.IsDebug == true ? "DEBUG" : "RELEASE")</p>
    </header>

    <section class="card">
        <h2>Navigation</h2>
        <p>Current route: <code>@CurrentRoute</code></p>
        <div class="btn-row">
            <button @onclick='() => NavigateTo("/about")'>Go to /about</button>
            <button @onclick='() => NavigateTo("/settings")'>Go to /settings</button>
        </div>
    </section>

    <section class="card">
        <h2>Storage</h2>
        <div class="input-row">
            <input @bind="StorageKey" placeholder="key" />
            <input @bind="StorageValue" placeholder="value" />
            <button @onclick="WriteStorage">Write</button>
            <button @onclick="ReadStorage">Read</button>
        </div>
        @if (StorageResult is not null)
        {
            <p class="result">→ <code>@StorageResult</code></p>
        }
    </section>

    <section class="card">
        <h2>Native Events</h2>
        <ul class="event-log">
            @foreach (var e in Events)
            {
                <li><span class="event-name">@e.Name</span> @e.Payload</li>
            }
        </ul>
        @if (!Events.Any())
        {
            <p class="muted">No events yet. Use POST /dev/event in DevTools.</p>
        }
    </section>
</div>

@code {
    private PlatformInfo? Info;
    private string CurrentRoute = "/";
    private string StorageKey = "";
    private string StorageValue = "";
    private string? StorageResult;
    private List<NativeEvent> Events = new();
    private AsyncEvent<NativeEvent>? _eventHandler;

    protected override async Task OnInitializedAsync()
    {
        Info = await Bridge.GetPlatformInfoAsync();
        CurrentRoute = await Bridge.GetCurrentRouteAsync();

        _eventHandler = (e, ct) =>
        {
            Events.Insert(0, e);
            if (Events.Count > 20) Events.RemoveAt(Events.Count - 1);
            _ = InvokeAsync(StateHasChanged);
            return ValueTask.CompletedTask;
        };
        Bridge.NativeEvents += _eventHandler;
    }

    private async Task NavigateTo(string route)
    {
        await Bridge.NavigateAsync(route);
        CurrentRoute = await Bridge.GetCurrentRouteAsync();
    }

    private async Task WriteStorage()
        => await Bridge.WriteStorageAsync(StorageKey, StorageValue);

    private async Task ReadStorage()
        => StorageResult = await Bridge.ReadStorageAsync(StorageKey) ?? "<not found>";

    public void Dispose()
    {
        if (_eventHandler is not null) Bridge.NativeEvents -= _eventHandler;
    }
}
