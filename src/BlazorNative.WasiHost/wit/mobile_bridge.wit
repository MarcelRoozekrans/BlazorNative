package blazornative:mobile-bridge@0.1.0;

// Phase 2.3 minimal contract: prove .NET-in-WASM can call out to the host.
// Six more imports (shell-navigate, shell-storage-*, shell-fetch) are
// documented as deferred-by-phase carryovers in docs/BACKLOG.md.
interface bridge {
  shell-platform-info: func() -> string;
}

world wasi-host {
  include wasi:cli/imports@0.2.0;
  import bridge;
  export wasi:cli/run@0.2.0;
}
