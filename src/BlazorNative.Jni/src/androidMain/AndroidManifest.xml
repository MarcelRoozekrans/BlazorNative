<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Phase 3.1: the shell bridge's fetch handler (AndroidShellBridge →
         HttpURLConnection) does real network I/O; Android requires INTERNET
         for ANY socket — including the instrumented tests' localhost
         ServerSocket responder (EPERM without it). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Phase 9.0 (M9 DoD #2): geolocation. The permission-gated async host call
         (AndroidShellBridge.hostCallBegin → requestPermissions → LocationManager)
         needs both fine and coarse; the platform LocationManager (fed by
         `adb emu geo fix` / a mock test provider) is the no-Play-Services path. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Phase 9.1 (M9 DoD #3): local notifications. POST_NOTIFICATIONS is the
         Android 13+ runtime permission the shell requests before show/schedule
         (inert below API 33, where notifications are implicitly permitted). The
         scheduled path uses an INEXACT AlarmManager alarm, so NO SCHEDULE_EXACT_ALARM
         is needed. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Phase 9.2 (M9 DoD #4): biometrics. USE_BIOMETRIC is a NORMAL permission
         (granted at install, NO runtime prompt) that BiometricPrompt / BiometricManager
         use. Secure storage's raw AndroidKeyStore needs no manifest permission. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <application
        android:label="BlazorNative"
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <activity
            android:name=".MainActivity"
            android:launchMode="singleTop"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Phase 5.1 (M5 DoD #5): launch-time deep links. A custom scheme
                 (blazornative://<route>) — no domain verification, the simplest
                 honest proof of the mechanism; https App Links are later work.
                 MainActivity.onCreate parses intent.data → seeds the startup
                 route before boot (the 3.5 startup-honor mounts the page). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="blazornative" />
            </intent-filter>
        </activity>

        <!-- Phase 9.1: the scheduled-notification publisher. MANIFEST-declared (not
             a runtime receiver) so a `schedule` alarm still fires after the process
             is killed. The nested binary name is Outer$Inner
             (AndroidShellBridge.NotificationPublisher). Not exported — only the
             app's own AlarmManager alarm targets it. -->
        <receiver
            android:name="io.blazornative.shell.AndroidShellBridge$NotificationPublisher"
            android:exported="false" />
    </application>

</manifest>
