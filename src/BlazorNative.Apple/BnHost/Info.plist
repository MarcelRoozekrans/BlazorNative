<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- ── Phase 6.3 Gate 3: ATS, AND THE NARROWEST EXEMPTION THAT WORKS ──────────
	     App Transport Security blocks cleartext HTTP, and **Kingfisher fetches through
	     URLSession, so ATS applies to it**. The image fixtures live on a LOOPBACK HTTP
	     server the XCTest target stands up in-process (http://127.0.0.1:8099 — 6.3
	     non-negotiable #5: CI never touches the public internet), and in the SIMULATOR
	     127.0.0.1 is the HOST MAC's loopback, so this is a real ATS-governed request.

	     Without this key every fetch fails — and the failure mode is the phase's most
	     dangerous one: a BLOCKED load is INDISTINGUISHABLE from the 404 that /image's
	     case [2] expects, so case [0] ("the frame did not move") and case [2] ("the
	     failure reserved nothing") BOTH STILL PASS on a device that loaded nothing. Only
	     case [1] reddens, and it reads as a reflow bug.

	     NSAllowsLocalNetworking, NOT NSAllowsArbitraryLoads: the narrow exemption for
	     loopback/link-local/.local destinations only. Public-internet HTTP stays blocked,
	     which is exactly the posture Android's debug network-security-config takes
	     (cleartext permitted to 127.0.0.1/localhost and nothing else).

	     `BnImageDemoTests.testCleartextLoopbackIsPermittedByATS` is what turns this from an
	     assumption into a checked fact — it pulls a fixture over the same cleartext
	     loopback Kingfisher uses, through URLSession, so a block names itself. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- ── Phase 9.0 Gate 3: the geolocation purpose string ───────────────────────
	     CLLocationManager.requestWhenInUseAuthorization() reads this string for the
	     system permission alert, and iOS CRASHES the app at the request call if the
	     key is absent (SIGABRT: "The app's Info.plist must contain an
	     NSLocationWhenInUseUsageDescription key"). A real sentence, not a placeholder —
	     the App Store rejects an empty/boilerplate purpose string, and it is the text a
	     real user reads. When-in-use only (foreground position); background/always is
	     M-out-of-scope, so NSLocationAlwaysAndWhenInUseUsageDescription is deliberately
	     NOT declared. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>BlazorNative uses your location to show your current position in the geolocation demo.</string>
	<!-- ── Phase 9.2 Gate 3: the Face ID purpose string ───────────────────────────
	     LAContext.evaluatePolicy(.deviceOwnerAuthenticationWithBiometrics) and a
	     SecItemCopyMatching on a .biometryCurrentSet Keychain item both read this string
	     for the Face ID system prompt, and iOS CRASHES the app at the evaluation if the
	     key is absent (SIGABRT on Face-ID devices). A real sentence, not a placeholder —
	     the App Store rejects an empty/boilerplate purpose string, and it is the text a
	     real user reads under the Face ID sheet. Touch ID needs no purpose string
	     (§3c) — this key covers the Face ID surface for both `authenticate` and the
	     OS-key-bound `getWithAuth`. -->
	<key>NSFaceIDUsageDescription</key>
	<string>BlazorNative uses Face ID to confirm it's you and to unlock secrets you store in the secure demo.</string>
	<!-- ── Phase 9.1 Gate 3: no Info.plist key for LOCAL notifications ─────────────
	     Unlike location (whose requestWhenInUseAuthorization CRASHES without a purpose
	     string), UNUserNotificationCenter authorization for LOCAL notifications is
	     purely runtime (requestAuthorization(options:)) and needs NO Info.plist key —
	     no purpose string, no UIBackgroundModes (a local notification is scheduled by
	     the app in-process, not delivered by a remote push). Recorded here so the
	     ABSENCE is a decision (the design §3b), not an omission. Remote push (aps-
	     environment entitlement + UIBackgroundModes:remote-notification) is out of
	     scope for the POC. -->

	<key>UILaunchStoryboardName</key>
	<string></string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
